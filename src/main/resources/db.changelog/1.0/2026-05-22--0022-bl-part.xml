<?xml version="1.0" encoding="utf-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-05-22--0022-bl-part" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="bl_part"/>
            </not>
        </preConditions>

        <createTable tableName="bl_part">
            <column name="rb_id" type="VARCHAR(20)">
                <constraints primaryKey="true" nullable="false" foreignKeyName="fk_rb_part_num" referencedTableName="part" referencedColumnNames="part_num"/>
            </column>

            <column name="id" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>

            <column name="image_url" type="VARCHAR"/>
        </createTable>
    </changeSet>
</databaseChangeLog>