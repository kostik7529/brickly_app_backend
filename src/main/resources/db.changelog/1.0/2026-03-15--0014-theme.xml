<?xml version="1.0" encoding="utf-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="2026-03-15--0014-theme" author="arseniy">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="theme"/>
            </not>
        </preConditions>

        <createTable tableName="theme">
            <column name="id" type="INTEGER" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>

            <column name="parent_id" type="INTEGER">
                <constraints referencedTableName="theme" referencedColumnNames="id" foreignKeyName="fk_theme_parent" nullable="true"/>
            </column>
        </createTable>

        <createIndex indexName="idx_theme_parent_id" tableName="theme">
            <column name="parent_id"/>
        </createIndex>

        <createIndex indexName="idx_theme_name" tableName="theme">
            <column name="name"/>
        </createIndex>

    </changeSet>
</databaseChangeLog>


