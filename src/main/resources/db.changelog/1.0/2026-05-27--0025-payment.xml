<?xml version="1.0" encoding="utf-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-05-27--0025-payment" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="payment"/>
            </not>
        </preConditions>

        <createTable tableName="payment">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_user_id" referencedTableName="user" referencedColumnNames="id"/>
            </column>

            <column name="amount" type="VARCHAR">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR">
                <constraints nullable="false"/>
            </column>

            <column name="yookassa_payment_id" type="VARCHAR">
                <constraints unique="true" nullable="false"/>
            </column>

            <column name="credited" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>