<?xml version="1.0" encoding="utf-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-05-14--0020-lot" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="lot"/>
            </not>
        </preConditions>

        <createTable tableName="lot">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(15)">
                <constraints nullable="false"/>
            </column>

            <column name="item_type" type="VARCHAR(1)">
                <constraints nullable="false"/>
            </column>

            <column name="item_id" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="quantity" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="VARCHAR(500)"/>

            <column name="condition" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>

            <column name="condition_rate" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="price" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="views_count" type="INTEGER" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>