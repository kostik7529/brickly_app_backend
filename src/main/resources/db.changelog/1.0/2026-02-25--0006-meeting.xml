<?xml version="1.0" encoding="utf-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="2026-02-25--0007-meeting" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="meeting"/>
            </not>
        </preConditions>

        <createTable tableName="meeting">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="address" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="type_id" type="INTEGER">
                <constraints nullable="false" referencedTableName="meeting_type" referencedColumnNames="id" foreignKeyName="fk_meeting_type"/>
            </column>

            <column name="ticket_price" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="discount_duration" type="INTEGER"/>

            <column name="discount_amount" type="INTEGER"/>

            <column name="discount_modifier" type="INTEGER"/>

        </createTable>
    </changeSet>

    <changeSet id="2026-03-21--0007-meeting" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists columnName="announce_date" tableName="meeting"/>
            </not>
            <not>
                <columnExists columnName="duration" tableName="meeting"/>
            </not>
        </preConditions>

        <addColumn tableName="meeting">
            <column name="announce_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="meeting">
            <column name="duration" type="INTEGER"/>
        </addColumn>
    </changeSet>

    <changeSet id="2026-05-16--0007-meeting" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists columnName="preview_img_path" tableName="meeting"/>
            </not>
            <not>
                <columnExists columnName="title" tableName="meeting"/>
            </not>
        </preConditions>

        <addColumn tableName="meeting">
            <column name="preview_image_path" type="VARCHAR(100)"/>
        </addColumn>

        <addColumn tableName="meeting">
            <column name="title" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
