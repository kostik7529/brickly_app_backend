<?xml version="1.0" encoding="utf-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="2026-02-25--0008-ticket" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="ticket"/>
            </not>
        </preConditions>

        <createTable tableName="ticket">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false" referencedTableName="user" referencedColumnNames="id" foreignKeyName="fk_ticket_user"/>
            </column>

            <column name="meeting_id" type="BIGINT">
                <constraints nullable="false" referencedTableName="meeting" referencedColumnNames="id" foreignKeyName="fk_ticket_meeting"/>
            </column>

            <column name="price_paid" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="state" type="INTEGER">
                <constraints nullable="false"/>
            </column>

        </createTable>


    </changeSet>
</databaseChangeLog>
