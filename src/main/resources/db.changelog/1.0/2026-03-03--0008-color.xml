<?xml version="1.0" encoding="utf-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="2026-03-03--0008-color" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="color"/>
            </not>
        </preConditions>

        <createTable tableName="color">
            <column name="id" type="INTEGER" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>

            <column name="rgb" type="VARCHAR(6)">
                <constraints nullable="false"/>
            </column>

            <column name="is_trans" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>

            <column name="num_parts" type="INTEGER"/>

            <column name="num_sets" type="INTEGER"/>

            <column name="y1" type="INTEGER"/>

            <column name="y2" type="INTEGER"/>

        </createTable>


    </changeSet>
</databaseChangeLog>
