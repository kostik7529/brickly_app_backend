<?xml version="1.0" encoding="utf-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="2026-03-03--0009-part-category" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="part"/>
            </not>
        </preConditions>

        <createTable tableName="part">
            <column name="part_num" type="VARCHAR(20)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(250)">
                <constraints nullable="false"/>
            </column>

            <column name="part_cat_id" type="INTEGER">
                <constraints referencedTableName="part_category" referencedColumnNames="id" foreignKeyName="fk_part_category" nullable="false"/>
            </column>

            <column name="part_material" type="VARCHAR(100)"/>

        </createTable>


    </changeSet>
</databaseChangeLog>
