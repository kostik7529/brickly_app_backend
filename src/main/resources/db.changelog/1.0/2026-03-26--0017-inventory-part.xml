<?xml version="1.0" encoding="utf-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-03-26--0017-inventory-part" author="kbadogin">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="inventory_part"/>
            </not>
        </preConditions>

        <createTable tableName="inventory_part">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="inventory_id" type="INTEGER">
                <constraints referencedTableName="inventory" referencedColumnNames="id" foreignKeyName="fk_pi_inventory" nullable="false"/>
            </column>

            <column name="part_num" type="VARCHAR(20)">
                <constraints referencedTableName="part" referencedColumnNames="part_num" foreignKeyName="fk_pi_part" nullable="false"/>
            </column>

            <column name="color_id" type="INTEGER">
                <constraints referencedTableName="color" referencedColumnNames="id" foreignKeyName="fk_pi_color" nullable="false"/>
            </column>

            <column name="quantity" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="is_spare" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>

            <column name="img_url" type="VARCHAR(150)"/>
        </createTable>
    </changeSet>
</databaseChangeLog>